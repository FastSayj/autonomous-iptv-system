# IPTV System Configuration
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Database
DB_PATH=./data/iptv.db
DB_BACKUP_PATH=./data/backups

# Source Discovery
SOURCE_UPDATE_INTERVAL=3600000
MAX_SOURCE_THREADS=10
SOURCE_TIMEOUT=10000

# Stream Validation
VALIDATION_TIMEOUT=5000
MAX_VALIDATION_THREADS=20
STREAM_CHECK_INTERVAL=1800000

# EPG Generation
EPG_UPDATE_INTERVAL=86400000
EPG_OUTPUT_PATH=./data/epg.xml
EPG_RETENTION_DAYS=30

# Playlist Generation
PLAYLIST_OUTPUT_PATH=./data/playlist.m3u
PLAYLIST_UPDATE_INTERVAL=1800000

# Crawler Settings
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
MAX_RETRIES=3
RETRY_DELAY=1000

# API Settings
API_PORT=3000
API_HOST=0.0.0.0
ENABLE_API_DOCS=true
